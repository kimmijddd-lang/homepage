{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "taxdy.co.kr"
        }
      ],
      "destination": "https://www.taxdy.co.kr/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/services/:slug",
      "destination": "/services/:slug/index.html"
    },
    {
      "source": "/guides/:slug",
      "destination": "/guides/:slug/index.html"
    },
    {
      "source": "/authors/:slug",
      "destination": "/authors/:slug/index.html"
    },
    {
      "source": "/contact",
      "destination": "/contact/index.html"
    },
    {
      "source": "/contact/thanks",
      "destination": "/contact/thanks/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    }
  ]
}
